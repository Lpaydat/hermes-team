# ── Exclude everything by default ───────────────────────────────
*

# ── Re-include: profile configs, skills, plugins, scripts ───────
!startup/
!startup/profiles/
!startup/profiles/*/
!startup/profiles/*/config.yaml
!startup/profiles/*/config/
!startup/profiles/*/config/**
!startup/profiles/*/skills/
!startup/profiles/*/skills/**
!startup/profiles/*/plugins/
!startup/profiles/*/plugins/**
!startup/profiles/*/scripts/
!startup/profiles/*/scripts/**
!startup/profiles/*/SOUL.md
!startup/profiles/*/SPECIALTY.md

# ── Re-include: general doctrine skills (autoresearch) ─────────
# startup/skills/ is the hub-managed skill store (runtime); only
# hand-authored doctrine skills are whitelisted individually.
!startup/skills/
!startup/skills/autoresearch/
!startup/skills/autoresearch/**

# ── Re-include: shared plugins source ───────────────────────────
!startup/plugins/
!startup/plugins/**

# ── Re-include: integration tests (parallel-dispatch proof) ────
!startup/tests/
!startup/tests/**

# ── Re-include: global config ───────────────────────────────────
!startup/config.yaml
!startup/kanban/
!startup/kanban/boards/
!startup/kanban/boards/*/
!startup/kanban/boards/*/kanban.db

# ── Re-include: shared skills ───────────────────────────────────
!shared-skills/
!shared-skills/**

# ── Re-include: hermes-agent source ─────────────────────────────
!startup/hermes-agent/
!startup/hermes-agent/**

# ── Re-include: gitignore itself ────────────────────────────────
!.gitignore

# ── Now exclude the bad stuff even inside re-included dirs ──────
# Database state files (keep kanban.db, exclude state.db)
startup/profiles/*/state.db
startup/profiles/*/state.db-*
startup/state.db
startup/state.db-*

# Sessions and logs
startup/profiles/*/sessions/
startup/profiles/*/logs/

# Python cache
**/__pycache__/
**/*.pyc

# Node modules
**/node_modules/

# .env (secrets)
**/.env

# Worktrees
**/.worktrees/

# Binaries
startup/bin/

# OS files
.DS_Store
Thumbs.db

# Large assets
*.mp4
*.mp3
*.wav
*.pdf

# External installed repos (reinstallable, not our config)
shared-skills/mattpocock/
shared-skills/mattpocock/
shared-skills/ponytail/
shared-skills/ponytail-hub/
startup/hermes-agent/

# Symlinks to shared skills (recreated by hermes skills install)
shared-skills/mattpocock
shared-skills/ponytail
startup/profiles/*/skills/mattpocock
startup/profiles/*/skills/ponytail
startup/hermes-agent

# Re-include: cron jobs
!startup/profiles/*/cron/
!startup/profiles/*/cron/**

# Exclude cron runtime state (keep only jobs.json)
startup/profiles/*/cron/.jobs.lock
startup/profiles/*/cron/.tick.lock
startup/profiles/*/cron/ticker_*
startup/profiles/*/cron/output/
startup/profiles/*/cron/output/**

# Skill curator runtime state (not config, regenerated on use)
startup/profiles/*/skills/.curator_state
startup/profiles/*/skills/.curator_backups/
startup/profiles/*/skills/.hub/.ignore
startup/profiles/*/skills/.hub/index-cache/

# Skill usage stats + locks (runtime, regenerated on use)
startup/profiles/*/skills/.usage.json
startup/profiles/*/skills/.usage.json.lock

# Self-edit backup snapshots (doctrine .bak.* — not source)
*.bak.*

# Test / validation / smoke board state (real boards tracked via the whitelist above)
startup/kanban/boards/dc-val-*/
startup/kanban/boards/debugger-smoke/
startup/kanban/boards/test88-design-v2/

# Test board artifacts (kanban_chains e2e test runs create these)
startup/kanban/boards/test*-kvstore*

# Plugin runtime state (regenerated by scanner)
startup/plugins/hermes-achievements/

# Re-include: README
!README.md

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key
.beads/proxieddb/

# Non-kanban SQLite databases (beads, state, etc.)
# Note: kanban.db files are re-included above via !startup/kanban/boards/*/kanban.db
startup/profiles/*/beads.db
*.state.db
